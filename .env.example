# Cursor User API Key (for SDK / deep analysis / research agents).
# Create one from (UI moves often):
#   https://cursor.com/dashboard/integrations  — scroll to "User API Keys"
#   or Cloud Agents → My Settings → API Keys
# Dashboard → API Keys with scope admin:* is the Admin API, not this.
CURSOR_API_KEY=crsr_...

# Email agent (SMTP) — required for ftse-email without --dry-run
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_TO=you@gmail.com
# EMAIL_FROM=you@gmail.com
# SMTP_USE_TLS=true

# Trading 212 Public API (catalogue / metadata — Cloud Agent secrets)
# Names must match exactly for injection:
#   TRADING212_API_KEY
#   TRADING212_API_SECRET
# Optional: TRADING212_ENV=demo|live  (default demo)
# After adding secrets, start a *new* Cloud Agent run (existing runs keep the old env).
# TRADING212_API_KEY=
# TRADING212_API_SECRET=
# TRADING212_ENV=demo

# Companies House Public Data API (free) — UK statutory accounts for research gap-fill
# https://developer.company-information.service.gov.uk/
# COMPANIES_HOUSE_API_KEY=
